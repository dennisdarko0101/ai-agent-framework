# LLM Provider API Keys
ANTHROPIC_API_KEY=sk-ant-xxxx
OPENAI_API_KEY=sk-xxxx

# Provider Configuration
DEFAULT_LLM_PROVIDER=claude          # claude or openai
DEFAULT_MODEL=claude-sonnet-4-20250514    # Model identifier
MAX_AGENT_STEPS=10                   # Max reasoning steps per task
SANDBOX_TIMEOUT=30                   # Code execution timeout (seconds)

# Memory
MEMORY_TYPE=conversation             # conversation, summary, or vector

# Logging
LOG_LEVEL=INFO                       # DEBUG, INFO, WARNING, ERROR
